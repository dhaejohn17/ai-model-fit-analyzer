# Copy this file to `.env` and adjust to match your setup.
#
# This app talks to any OpenAI-compatible Chat Completions API, so it works
# with local runtimes (Ollama, LM Studio, vLLM, llama.cpp, Jan) and hosted
# providers (OpenAI, Groq, Together, OpenRouter, Mistral, ...).

# AI_BASE_URL: Base URL of the OpenAI-compatible endpoint.
#   Ollama:    http://localhost:11434/v1   (default)
#   LM Studio: http://localhost:1234/v1
#   vLLM:      http://localhost:8000/v1
#   OpenAI:    https://api.openai.com/v1
#   Groq:      https://api.groq.com/openai/v1
AI_BASE_URL="http://localhost:11434/v1"

# AI_MODEL: The model name/tag to run. Must be a model your provider has available.
#   For Ollama, pull it first, e.g. `ollama pull llama3.1`
#   Examples: llama3.1 | qwen2.5-coder:7b-instruct | gpt-4o-mini | llama-3.1-8b-instant
AI_MODEL="llama3.1"

# AI_API_KEY: Bearer token for the provider.
#   Leave empty for local runtimes (Ollama / LM Studio don't need one).
#   Required for hosted providers (OpenAI, Groq, Together, ...).
AI_API_KEY=""
